<?xml version="1.0" encoding="utf-8"?>
<ArcGIS defaultAssembly="ProSalahBridge.dll"
        defaultNamespace="ProSalahBridge"
        xmlns="http://schemas.esri.com/DADF/Registry"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://schemas.esri.com/DADF/Registry file:///{ProgramFiles}/ArcGIS/Pro/bin/ArcGIS.Desktop.Framework.xsd">

  <AddInInfo id="{6f3a1c2e-9b47-4d0a-8e21-5c7f0a9b4d10}" version="0.1.2" desktopVersion="3.7">
    <Name>ProSalahBridge</Name>
    <Description>
      <pre>Live bridge that exposes the open ArcGIS Pro session to the ArcGIS Pro Salah MCP server</pre>
    </Description>
    <Image>Images\AddinDesktop32.png</Image>
    <Author>Ahmed Salah Muhammed</Author>
    <Company>Salah</Company>
    <Date>2026-06-20</Date>
    <Subject>Framework</Subject>
  </AddInInfo>

  <modules>
    <!-- autoLoad="true" so Module1.Initialize() runs (and the bridge starts) as
         soon as a project opens. -->
    <insertModule id="ProSalahBridge_Module"
                  className="Module1"
                  autoLoad="true"
                  caption="Pro Salah Bridge">
      <tabs>
        <tab id="ProSalahBridge_Tab" caption="Salah MCP" keytip="B">
          <group refID="Salah_MCP_LiveGroup" />
          <group refID="Salah_MCP_OnlineGroup" />
          <group refID="Salah_MCP_WebAppGroup" />
        </tab>
      </tabs>
      <groups>
        <group id="Salah_MCP_LiveGroup" caption="Live Bridge" appearsOnAddInTab="false">
          <button refID="Salah_MCP_StartServerBtn" size="large" />
          <button refID="Salah_MCP_PingBtn" size="large" />
        </group>
        <group id="Salah_MCP_OnlineGroup" caption="ArcGIS Online" appearsOnAddInTab="false">
          <button refID="Salah_MCP_PublishBtn" size="large" />
        </group>
        <!-- Web App: step 1 generate + preview on localhost, step 2 deploy to GitHub. -->
        <group id="Salah_MCP_WebAppGroup" caption="Web App" appearsOnAddInTab="false">
          <button refID="Salah_MCP_PreviewAppBtn" size="large" />
          <button refID="Salah_MCP_DashboardBtn" size="large" />
          <button refID="Salah_MCP_CreateAppBtn" size="large" />
        </group>
      </groups>
      <controls>
        <button id="Salah_MCP_StartServerBtn" caption="Start Server"
                className="StartServerButton" loadOnClick="true"
                smallImage="Images\StartServer16.png" largeImage="Images\StartServer32.png">
          <tooltip heading="Start / stop the bridge">
            Start or stop the loopback HTTP listener, then talk to Claude / Antigravity over MCP.<disabledText /></tooltip>
        </button>
        <button id="Salah_MCP_PingBtn" caption="Ping"
                className="PingButton" loadOnClick="true"
                smallImage="Images\Ping16.png" largeImage="Images\Ping32.png">
          <tooltip heading="Ping the bridge">
            GET /health on the loopback listener and show the response.<disabledText /></tooltip>
        </button>
        <button id="Salah_MCP_PublishBtn" caption="Publish"
                className="PublishButton" loadOnClick="true"
                smallImage="Images\Publish16.png" largeImage="Images\Publish32.png">
          <tooltip heading="Publish to ArcGIS Online">
            Pick feature layers from a checklist and publish them straight to your signed-in portal (into a new folder).<disabledText /></tooltip>
        </button>
        <button id="Salah_MCP_PreviewAppBtn" caption="Create Web App"
                className="PreviewWebAppButton" loadOnClick="true"
                smallImage="Images\PreviewApp16.png" largeImage="Images\PreviewApp32.png">
          <tooltip heading="Create &amp; preview the web app">
            Generate a static ArcGIS Maps SDK for JS app from a Web Map (or layers) and preview it in your browser on localhost — before deploying.<disabledText /></tooltip>
        </button>
        <button id="Salah_MCP_DashboardBtn" caption="Create Dashboard"
                className="PreviewDashboardButton" loadOnClick="true"
                smallImage="Images\Dashboard16.png" largeImage="Images\Dashboard32.png">
          <tooltip heading="Create &amp; preview an interactive dashboard">
            Generate an Esri-Dashboard-style web app — map + live indicators that recompute as you zoom/pan, a category breakdown and a features-in-view list — and preview it on localhost.<disabledText /></tooltip>
        </button>
        <button id="Salah_MCP_CreateAppBtn" caption="Deploy Web App"
                className="CreateWebAppButton" loadOnClick="true"
                smallImage="Images\CreateApp16.png" largeImage="Images\CreateApp32.png">
          <tooltip heading="Deploy the web app to GitHub">
            Push the previewed static web app to a new GitHub repo and optionally enable GitHub Pages (live site).<disabledText /></tooltip>
        </button>
      </controls>
    </insertModule>
  </modules>

</ArcGIS>
